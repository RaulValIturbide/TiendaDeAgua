<UserControl x:Class="Componentes.BarraBotones"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Componentes"
             mc:Ignorable="d" 
             d:DesignHeight="70" d:DesignWidth="900">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1.3*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Button Grid.Column="0" Background="SeaGreen" x:Name="btnNuevo" Click="btnNuevo_Click">
            <StackPanel Orientation="Horizontal"  >
                <Image Source="/Componentes;component/data/img/plus.png" Width="30" Height="30" Margin="0,0,5,0"/>
                <TextBlock Text="NUEVO" FontSize="30" VerticalAlignment="Center" FontFamily="Segoe UI Semibold"/>
            </StackPanel>
        </Button>

        <Button Grid.Column="1" Background="Orange" x:Name="btnPermitirModificar" Click="btnPermitirModificar_Click" Margin="10,0,0,0">
            <StackPanel Orientation="Horizontal"  >
                <Image Source="/Componentes;component/data/img/modificar.png" Width="30" Height="30" Margin="0,0,5,0"/>
                <TextBlock Text="MODIFICAR" FontSize="30" VerticalAlignment="Center" FontFamily="Segoe UI Semibold"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Button>



    </Grid>
</UserControl>
