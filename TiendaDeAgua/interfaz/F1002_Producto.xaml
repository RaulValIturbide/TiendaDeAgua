<Page x:Class="TiendaDeAgua.interfaz.F1002_Producto"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
     xmlns:local="clr-namespace:TiendaDeAgua.interfaz"
        xmlns:util="clr-namespace:Utilidades;assembly=Utilidades"
        mc:Ignorable="d" 
        d:DesignHeight="450" d:DesignWidth="1000"
        Title="PRODUCTO" MouseRightButtonUp="Page_MouseRightButtonUp">
    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{StaticResource AzulSecundarioAiron}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>
            <Label Grid.Row="0" Grid.Column="1" Content="ADMINISTRACIÓN DE PRODUCTOS" 
               Background="{StaticResource AzulSecundarioAiron}"
               FontSize="30"
               FontFamily="Segoe UI Semibold"
               Foreground="{StaticResource BlancoAiron}"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"/>

            <util:BotonMenuPrincipal Grid.Column="0" ToolTip="Vuelve al Menú Principal" 
                                     btnMenuPrincipal="BotonMenuPrincipal_btnMenuPrincipal"
                                     />
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.8*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <DataGrid Grid.Column="0" x:Name="dtgProducto" SelectionChanged="dtgProducto_SelectionChanged"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Margin="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="1*"/>
                    <DataGridTextColumn Header="Precio" Binding="{Binding Precio}" Width="1*"/>
                    <DataGridTextColumn Header="Stock" Binding="{Binding Stock}" Width="1*"/>
                    <DataGridTextColumn Header="Categoria" Binding="{Binding Categoria}" Width="1*"/>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <util:BarraBotones Grid.Row="0" Padding="5" VerticalAlignment="Center" 
                                   x:Name="BarraBotones_Principal"
                                   NuevoClick="btnNuevo_Click"
                                   ModificarClick="btnModificar_Click"
                                   CancelarClick="btnCancelar_Click"
                                   GuardarClick="btnGuardar_Click"
                                   EliminarClick="btnEliminar_Click"/>
                <GroupBox Header="MTO Producto" Grid.Row="1" x:Name="gbProducto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="5" />
                            <RowDefinition Height="1*" MaxHeight="70"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="1*"  MaxHeight="70"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="1*" MaxHeight="70"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="1*" MaxHeight="70"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Nombre-->
                        <Label Grid.Row="1" Grid.Column="0" Content="Nombre" Style="{StaticResource estiloLabel}"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Nombre}" Style="{StaticResource estiloTextBox}"/>

                        <!-- Precio -->
                        <Label Grid.Row="3" Grid.Column="0" Content="Precio" Style="{StaticResource estiloLabel}"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Precio}" Style="{StaticResource estiloTextBox}"/>

                        <!-- Stock -->
                        <Label Grid.Row="5" Grid.Column="0" Content="Stock" Style="{StaticResource estiloLabel}"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Stock}" Style="{StaticResource estiloTextBox}"/>
                        
                        <!-- CATEGORIA -->
                        <Label Grid.Row="7" Grid.Column="0" Content="Categoria" Style="{StaticResource estiloLabel}"/>
                        <ComboBox Grid.Row="7" Grid.Column="1" DisplayMemberPath="Texto" SelectedValuePath="Identificador"
                                  SelectedValue="{Binding CategoriaID}" Style="{StaticResource estiloComboBox}"
                                  x:Name="cboCategoria"/>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</Page>
