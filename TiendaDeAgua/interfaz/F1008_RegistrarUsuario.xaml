<Window x:Class="TiendaDeAgua.interfaz.F1008_RegistrarUsuario"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"         
        xmlns:local="clr-namespace:TiendaDeAgua.interfaz"
        xmlns:util="clr-namespace:Utilidades;assembly=Utilidades"
        mc:Ignorable="d" 
        Height="700" Width="500"
        Title="Registro Usuario" ResizeMode="NoResize" 
        Icon="/Utilidades;component/data/img/AironIcono.png"
        WindowStartupLocation="CenterScreen"
        >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="{StaticResource AzulSecundarioAiron}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Grid.Column="1" Source="/Utilidades;component/data/img/AironSplashScreenInversa.png"/>
        </Grid>
        <Grid Grid.Row="1" Background="{StaticResource BlancoAiron}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="5*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="6*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="1" Grid.Column="1" x:Name="dtgUsuario">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.6*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="1*" MaxHeight="70"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="1*" MaxHeight="70"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="1*" MaxHeight="70"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="1*" MaxHeight="70"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="1*" MaxHeight="70"/>
                    <RowDefinition Height="10"/>
                </Grid.RowDefinitions>

                <!-- NOMBRE USUARIO -->
                <Label Grid.Row="1" Grid.Column="0" Content="Nombre*" Style="{StaticResource estiloLabel}"/>
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Nombre}" Style="{StaticResource estiloTextBox}"/>
                <!-- CONTRASENYA -->
                <Label Grid.Row="3" Grid.Column="0" Content="Contraseña*" Style="{StaticResource estiloLabel}"/>
                <PasswordBox Grid.Row="3" Grid.Column="1" Style="{StaticResource estiloContrasenya}" x:Name="passPrimera"/>

                <!-- REPETIR CONTRASENYA -->
                <Label Grid.Row="5" Grid.Column="0" Content="Repetir Contraseña*" Style="{StaticResource estiloLabel}"/>
                <PasswordBox Grid.Row="5" Grid.Column="1" Style="{StaticResource estiloContrasenya}" x:Name="passRepetir"/>
                
                <!-- EMAIL -->
                <Label Grid.Row="7" Grid.Column="0" Content="Email" Style="{StaticResource estiloLabel}"/>
                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding Email}" Style="{StaticResource estiloTextBox}"/>
                
                <!-- BOTON ACEPTAR -->
                <Button Grid.Column="1" Grid.Row="9" x:Name="btnRegistrar" Content="Registrarse" Style="{StaticResource estiloBoton}"
                        Click="btnRegistrar_Click"/>
            </Grid>
            <TextBlock Grid.Row="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray">
                * Campos obligatorios
            </TextBlock>
        </Grid>
    </Grid>
</Window>
