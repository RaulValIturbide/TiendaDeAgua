<Page x:Class="TiendaDeAgua.interfaz.F1007_DetallesPedido"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:TiendaDeAgua.interfaz"
            xmlns:util="clr-namespace:Utilidades;assembly=Utilidades"
            mc:Ignorable="d" 
            d:DesignHeight="800" d:DesignWidth="800"
            Title="DetallesPedido">
    <Grid MouseRightButtonUp="Grid_MouseRightButtonUp">
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="{StaticResource AzulSecundarioAiron}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>
            <Label x:Name="lbTitulo" Grid.Column="1" Content="TXT_NOMBRE_PEDIDO" 
              Background="{StaticResource AzulSecundarioAiron}"
              FontSize="30"
              FontFamily="Segoe UI Semibold"
              Foreground="{StaticResource BlancoAiron}"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"/>

            <util:BotonMenuPrincipal Grid.Column="0" ToolTip="Vuelve al Menú Principal" 
                                    btnMenuPrincipal="BotonMenuPrincipal_btnMenuPrincipal"
                                    />
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.8*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>
            <DataGrid Grid.Column="0" x:Name="dtgDetallePedido" SelectionChanged="dtgDetallePedido_SelectionChanged"
                     AutoGenerateColumns="False" IsReadOnly="True"
                     Margin="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Producto Nombre" Binding="{Binding ProductoNombre}" Width="1*"/>
                    <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="1*"/>
                    <DataGridTextColumn Header="Precio por Ud" Binding="{Binding PrecioUnitario}" Width="1*"/>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>
                <util:BarraBotones Grid.Row="0" Padding="5" VerticalAlignment="Center" 
                                  x:Name="BarraBotones_Principal"
                                  NuevoClick="btnNuevo_Click"
                                  ModificarClick="btnModificar_Click"
                                  CancelarClick="btnCancelar_Click"
                                  GuardarClick="btnGuardar_Click"
                                  EliminarClick="btnEliminar_Click"
                                  InformeClick="btnInforme_Click"/>
                <GroupBox Header="MTO Producto" Grid.Row="1" x:Name="gbProducto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="5" />
                            <RowDefinition Height="1*" MaxHeight="70"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="1*"  MaxHeight="70"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="1*" MaxHeight="70"/>
                            <RowDefinition Height="5"/>
                            <RowDefinition Height="1*" MaxHeight="70"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Producto ID -->
                        <Label Grid.Row="1" Grid.Column="0" Content="Producto" Style="{StaticResource estiloLabel}"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cboProductoID" DisplayMemberPath="Texto" SelectedValuePath="Identificador"
                                  SelectedValue="{Binding ProductoID}" Style="{StaticResource estiloComboBox}"/>

                        <!-- CAntidad -->
                        <Label Grid.Row="3" Grid.Column="0" Content="Cantidad" Style="{StaticResource estiloLabel}"/>
                        <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Cantidad}" Style="{StaticResource estiloTextBox}"/>

                        <!-- Precio Unitario -->
                        <Label Grid.Row="5" Grid.Column="0" Content="Precio Ud" Style="{StaticResource estiloLabel}"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding PrecioUnitario}" Style="{StaticResource estiloTextBox}"/>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</Page>
