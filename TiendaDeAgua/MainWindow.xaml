<Window x:Class="TiendaDeAgua.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TiendaDeAgua"
        xmlns:util="clr-namespace:Utilidades;assembly=Utilidades"
        WindowStartupLocation="CenterScreen"
        Icon="/data/img/AironIcono.png"
        mc:Ignorable="d"
        Title="Pagina Principal" Height="800" Width="1000">
    <Grid>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
        </Grid>
        <TabControl x:Name="tabControlPrincipal">
            <TabItem Header="Entrar Usuario" x:Name="tbItemLogin">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="3*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Image Source="/data/img/AironSplashScreen.png" Grid.Column="1"/>
                    </Grid>
                    <Grid Grid.Row="1" x:Name="dtgDatosUsuario">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"  MaxWidth="200"/>
                            <ColumnDefinition Width="2*" MaxWidth="400"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*" MaxHeight="100"/>
                            <RowDefinition Height="1*" MaxHeight="100"/>
                            <RowDefinition Height="1*"/>
                        </Grid.RowDefinitions>
                        
                        <!-- NOMBRE -->
                        <Label Grid.Row="0" Grid.Column="1" Content="Nombre Usuario" Style="{StaticResource estiloLabel}"/>
                        <TextBox  Grid.Row="0" Grid.Column="2" Text="{Binding Nombre}" Style="{StaticResource estiloTextBox}"/>
                        
                        <!-- CONTRASENYA -->
                        <Label Grid.Row="1" Grid.Column="1" Content="Contraseña" Style="{StaticResource estiloLabel}"/>
                        <PasswordBox x:Name="cajaContra" Grid.Row="1" Grid.Column="2" PasswordChanged="PasswordBox_PasswordChanged" Style="{StaticResource estiloContrasenya}"/>

                        <!-- Contrasenya pero textbox -->
                        <TextBox x:Name="txtContra" Grid.Row="1" Text="{Binding Contrasenya}" 
                                 Grid.Column="2" Style="{StaticResource estiloTextBox}"
                                 Visibility="Collapsed"/>

                        <!-- check box mostrar/ocultar la contra -->
                        <CheckBox  x:Name="ckBoxMostrarContra" Content="Mostrar Contraseña" IsThreeState="False" 
                                   IsChecked="False" 
                                   Checked="ckBoxMostrarContra_Checked"
                                   Unchecked="ckBoxMostrarContra_Unchecked"
                                   Grid.Row="1" Grid.Column="3"
                                   VerticalAlignment="Bottom"
                                   Margin="20"/>
                        
                        
                        <Grid Grid.Row="2" Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition  Height="1*"/>
                                <RowDefinition  Height="1*"/>
                                <RowDefinition  Height="1*"/>
                            </Grid.RowDefinitions>
                            <!-- Botno Acceder -->
                            <Button Grid.Column="0" Grid.Row="0" x:Name="btnAcceder" Content="Acceder" 
                                    Click="btnAcceder_Click" Margin="10" Style="{StaticResource estiloBoton}"/>
                            <!-- Boton Registrar Usuario -->
                            <Button Grid.Column="1" Grid.Row="0" x:Name="btnRegistrar" Content="Registrate"
                                    Click="btnRegistrar_Click" Margin="10" Style="{StaticResource estiloBoton}"/>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Pagina Principal"  x:Name="tbItemPaginaPrincipal" Background="{StaticResource BlancoAiron}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="100"/>
                        <RowDefinition Height="1*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid Background="{StaticResource AzulSecundarioAiron}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <Label x:Name="lbSaludo" Style="{StaticResource estiloLabelSaludo}" Grid.Column="0"/>
                            <Image Source="/data/img/AironSplashScreenInversa.png" Grid.Column="1" HorizontalAlignment="Right"/>
                        </Grid>


                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="1*"/>
                            <RowDefinition Height="1*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!-- TARJETA PROVEEDOR -->
                        <util:Tarjeta Grid.Row="1" Grid.Column="1" x:Name="TarjetaProveedor"/>
                        
                        <!-- TARJETA INVENTARIO -->
                        <util:Tarjeta Grid.Row="1" Grid.Column="2" x:Name="TarjetaInventario"/>
                        
                        <!-- TARJETA CLIENTES -->
                        <util:Tarjeta Grid.Row="2" Grid.Column="1" x:Name="TarjetaCliente"/>
                        
                        <!-- TARJETA Administrador -->
                        <util:Tarjeta Grid.Row="2" Grid.Column="2" x:Name="TarjetaAdministrador"/>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Visibility="Collapsed" x:Name="tbItemProveedor" Header="Proveedores">
                <Frame x:Name="frameProveedor" NavigationUIVisibility="Hidden"/>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
