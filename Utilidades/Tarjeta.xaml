<UserControl x:Class="Utilidades.Tarjeta"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Utilidades"
             mc:Ignorable="d"
             d:Width="300" d:Height="150">
    <Grid>
        <Button Background="{StaticResource AzulSecundarioAiron}" Click="Button_Click" Margin="10">
            <TextBlock Text="{Binding Nombre}" Foreground="{StaticResource BlancoAiron}"
                       FontSize="20"
                       FontFamily="Segoe UI Semibold"
                       />
        </Button>

    </Grid>
</UserControl>
