<Window x:Class="Utilidades.Recursos.VentanaError"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Utilidades.Recursos"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d"
        Title="VentanaError" Height="300" Width="500" ResizeMode="NoResize"
        >
    <Grid KeyDown="BtnAceptar_KeyDown">
        <Grid.RowDefinitions>
            <RowDefinition Height="1.5*"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="2*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <Image x:Name="imgVentanaError" Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Margin="10"/>

        <TextBlock Grid.Row="0"
                   Grid.Column="1"
                   x:Name="txtBkCodigo"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="20"
                   FontWeight="Bold"
                   FontFamily="Segoe UI Semibold"/>

        <TextBlock Grid.Row="1"
           Grid.Column="1"
           x:Name="txtBlockInformacion"
           TextWrapping="Wrap"
           VerticalAlignment="Stretch"
           HorizontalAlignment="Stretch"
           FontFamily="Calibri Light"
           FontSize="16"
           Margin="20,0,0,0"/>

        <Button Grid.Column="1" Grid.Row="2" x:Name="btnAceptar" Click="btnAceptar_Click" Content="Aceptar" 
                Style="{StaticResource estiloBoton}"
                Margin="10,5,10,5"/>

    </Grid>
</Window>
