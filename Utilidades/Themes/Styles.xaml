<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="AzulAiron" Color="#003E61"/>
    <SolidColorBrush x:Key="BlancoAiron" Color="#F0F8FF"/>

    <SolidColorBrush x:Key="AzulSecundarioAiron" Color="#1A5A80"/>


    <!-- PARA EL TAB ITEM-->
    <Style x:Key="estiloTabItem" TargetType="TabItem">
        <Setter  Property="Background" Value="#F0F8FF "/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
    </Style>

    <!-- PARA LA LABEL -->
    <Style x:Key="estiloLabel" TargetType="Label">
        <Setter Property="Background" Value="#1A5A80 "/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="Foreground" Value="{StaticResource BlancoAiron}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Padding" Value="20"/>
        <Setter Property="FontFamily" Value="Calibri"/>
        <Setter Property="MaxHeight" Value="60"/>
    </Style>
    
    <!-- PARA LA TEXTBOX -->
    <Style x:Key="estiloTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BlancoAiron}"/>
        <Setter Property="HorizontalAlignment"  Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontFamily" Value="Calibri Light"/>
        <Setter Property="MaxHeight"  Value="60"/>
    </Style>
    
    <!-- PARA LOS BOTONES -->
    <Style x:Key="estiloBoton"  TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AzulSecundarioAiron}"/>
        <Setter Property="MaxHeight" Value="60"/>
        <Setter Property="MaxWidth"  Value="200"/>
        <Setter Property="Foreground" Value="{StaticResource BlancoAiron}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontFamily" Value="Calibri"/>
    </Style>

    <!-- PARA La contraseña -->
    <Style x:Key="estiloContrasenya" TargetType="PasswordBox">
        <Setter Property="Background" Value="{StaticResource BlancoAiron}"/>
        <Setter Property="HorizontalAlignment"  Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontFamily" Value="Calibri Light"/>
        <Setter Property="MaxHeight"  Value="60"/>
    </Style>
    
    <!-- PARA Label  Titulo -->
    <Style x:Key="estiloLabelSaludo" TargetType="Label">
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Margin" Value="20,0,0,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{StaticResource BlancoAiron}"/>
    </Style>
    
    <!-- PARA COMBO BOX -->
    <Style x:Key="estiloComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource BlancoAiron}"/>
        <Setter Property="MaxHeight" Value="60"/>
        <Setter Property="HorizontalAlignment"  Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontFamily" Value="Calibri Light"/>
        <Setter Property="MaxHeight"  Value="60"/>
    </Style>

</ResourceDictionary>