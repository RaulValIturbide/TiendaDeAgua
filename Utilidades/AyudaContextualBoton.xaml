<UserControl x:Class="Utilidades.AyudaContextualBoton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Button x:Name="btnAyuda"
                Width="64"
                Height="64"
                Click="btnAyuda_Click"
                Padding="0"
                BorderThickness="0"
                Background="Transparent">

            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <!-- Círculo -->
                        <Ellipse Fill="Transparent"
                                 StrokeThickness="0"/>

                        <!-- Imagen -->
                        <Image Source="/Utilidades;component/data/img/AyudaContextual.png"
                               Stretch="Uniform" Cursor="Hand"/>
                    </Grid>
                </ControlTemplate>
            </Button.Template>

        </Button>
    </Grid>
</UserControl>
